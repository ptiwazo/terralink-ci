# --- Backend TerraLink CI (apps/api) ---
# Copier en `.env` dans ce dossier. NE JAMAIS committer le vrai .env.

# Base de données principale (doit correspondre à infra/docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://terralink:terralink@localhost:5432/terralink

# Base de données dédiée aux tests automatisés
TEST_DATABASE_URL=postgresql+psycopg2://terralink:terralink@localhost:5432/terralink_test

# Secret JWT — GÉNÉRER une vraie valeur aléatoire en prod (ex: `openssl rand -hex 32`)
JWT_SECRET=dev-secret-a-changer-absolument-en-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — origine du front Vite en dev
FRONTEND_ORIGIN=http://localhost:5173

# Environnement: dev | test | prod
ENVIRONMENT=dev

# --- Paiement / Escrow (Phase 2) ---
# Fournisseur actif : sandbox (dev/tests) ou mobile_money (squelette).
PAYMENT_PROVIDER=sandbox
# Secret de signature HMAC des webhooks entrants — À CHANGER en prod.
WEBHOOK_SECRET=dev-webhook-secret-a-changer
# Commission plateforme en points de base (500 = 5,00 %).
COMMISSION_BPS=500
